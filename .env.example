# Timely API credentials (required)
TIMELY_USERNAME=ubcabholding
TIMELY_PASSWORD=replace-me

# Default 7-digit company register (optional — tools fall back to this)
TIMELY_COMPANY_REGISTER=

# Override the API base URL (optional)
# TIMELY_BASE_URL=https://api.timely.mn

# --- Remote (Vercel) deployment only ---
# Secret bearer token clients must send to reach the /mcp endpoint.
# Generate one with:  openssl rand -hex 32
# REQUIRED in production — the endpoint fails closed without it.
TIMELY_MCP_AUTH_TOKEN=
